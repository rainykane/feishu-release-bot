# Feishu App
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxx
FEISHU_BOT_NAME=Release Bot

# GitHub — multi-project (recommended)
# JSON array: each project needs name, owner, repo, workflowId
GITHUB_PROJECTS=[{"name":"livetranslator","owner":"timekettle","repo":"livetranslator","workflowId":"release.yml"}]
GITHUB_TOKEN=ghp_xxxxxxxx
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub — legacy single-project format (still supported)
# GITHUB_OWNER=timekettle
# GITHUB_REPO=livetranslator
# GITHUB_WORKFLOW_ID=release.yml

# Server
PORT=3000
